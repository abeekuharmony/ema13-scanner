# Telegram Bot Configuration
# Create a bot via @BotFather on Telegram, then get your chat_id
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Twelve Data API Key (register at https://twelvedata.com)
# Required for forex/commodity signals (EUR/USD, GBP/USD, XAU/USD, etc.)
TWELVEDATA_API_KEY=your_api_key_here

# Scanner Settings (optional — these are the defaults)
SCAN_INTERVAL_MINUTES=1
CANDLE_LIMIT=100
LOG_LEVEL=INFO
