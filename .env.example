# Telegram Bot Configuration
# Create a bot via @BotFather on Telegram, then get your chat_id
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Twelve Data API Key (register at https://twelvedata.com)
TWELVEDATA_API_KEY=your_api_key_here

# Scanner Settings
SCAN_INTERVAL_MINUTES=1
BINANCE_TOP_N=25
EMA_PERIOD=13
CANDLE_LIMIT=50
LOG_LEVEL=INFO
